#!/usr/bin/env bash
set -euxo pipefail

APPCAST_URL="${CODEX_APPCAST_URL:-https://persistent.oaistatic.com/codex-app-prod/appcast.xml}"
CACHE_DIR="${CODEX_APP_ZIP_CACHE_DIR:-.cache/codex-app-zips}"

if [[ -z "${APP_VERSION:-}" ]]; then
  APP_VERSION="$(
    curl -fsSL "$APPCAST_URL" |
      sed -n 's#.*<sparkle:shortVersionString>\([^<]*\)</sparkle:shortVersionString>.*#\1#p' |
      head -1
  )"
fi

if [[ -z "$APP_VERSION" ]]; then
  echo "Unable to resolve Codex App version from $APPCAST_URL" >&2
  exit 1
fi

mkdir -p "$CACHE_DIR"
HOSTED_CODEX_APP_ZIP="$CACHE_DIR/Codex-darwin-arm64-$APP_VERSION.zip"
if [[ ! -s "$HOSTED_CODEX_APP_ZIP" ]]; then
  curl -fL -o "$HOSTED_CODEX_APP_ZIP" \
    "https://persistent.oaistatic.com/codex-app-prod/Codex-darwin-arm64-$APP_VERSION.zip"
fi

HOSTED_CODEX_APP_ZIP="$HOSTED_CODEX_APP_ZIP" bash ./scripts/prepare_asar
